# Copy this file to .env.local for `vercel dev`, or paste the same
# variables into Vercel Dashboard -> Project Settings -> Environment
# Variables for the deployed function to pick them up.

# --- Mailer (Brevo HTTP API) ------------------------------------------
# Free 300 emails/day at https://www.brevo.com  (no SMTP needed, works
# on hosts that block outbound SMTP like Render Free Tier).
#
# 1. Sign up at brevo.com (no SMS, no domain required).
# 2. Settings -> Senders, Domains & Dedicated IPs -> Senders ->
#    "Add a sender". Use your own Gmail; Brevo sends a verification
#    link to that inbox — click it.
# 3. SMTP & API -> API Keys -> "Generate a new API key" (v3 key).

# Sender email — must be a verified sender in your Brevo account.
MAIL_SENDER_EMAIL=your.account@gmail.com

# Display name on outgoing mail.
MAIL_SENDER_NAME=CV Contact Form

# Brevo v3 API key (xkeysib-...).
BREVO_API_KEY=

# Optional. Where the "new message" letter is delivered.
# Defaults to MAIL_SENDER_EMAIL if omitted.
MAIL_OWNER=your.account@gmail.com

# --- AI chat (Groq) ---------------------------------------------------
# Free API key from https://console.groq.com (no card required).
GROQ_API_KEY=

# --- CORS allowlist ---------------------------------------------------
# Comma-separated list of origins allowed to call the API. The frontend
# is hosted on GitHub Pages, so its origin must be here in production.
# `vercel dev` adds localhost automatically.
ALLOWED_ORIGIN=https://nick-konstantinov.github.io,http://localhost:3000,http://127.0.0.1:3000
