# Copy this file to .env.local for `vercel dev`, or paste the same
# variables into Vercel Dashboard -> Project Settings -> Environment
# Variables for the deployed function to pick them up.

# --- Mailer (Nodemailer + Gmail SMTP) ---------------------------------
# Gmail address that will SEND the messages. Owner letters arrive here
# by default, copies are sent to the visitor's email.
GMAIL_USER=your.account@gmail.com

# 16-character Google App Password (NOT your real Gmail password!).
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification enabled on the Google account.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional. Where the "new message" letter is delivered.
# Defaults to GMAIL_USER if omitted.
MAIL_OWNER=your.account@gmail.com

# --- AI chat (Groq) ---------------------------------------------------
# Free API key from https://console.groq.com (no card required).
GROQ_API_KEY=

# --- CORS allowlist ---------------------------------------------------
# Comma-separated list of origins allowed to call the API. The frontend
# is hosted on GitHub Pages, so its origin must be here in production.
# `vercel dev` adds localhost automatically.
ALLOWED_ORIGIN=https://nick-konstantinov.github.io,http://localhost:3000,http://127.0.0.1:3000
